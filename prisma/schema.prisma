// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum WorldOfTanksMapName {
  Cliff
  GhostTown
  Himmelsdorf
  Westfield
  Pilsen
  SandRiver
  Tundra
  Ruinberg
  Ensk
}

enum PickBanStepAction {
  MapBan
  MapPick
  SidePick
}

enum MapSide {
  North
  South
  East
  West
}

enum ActingTeam {
  TeamA
  TeamB
}

enum PickBanFormat {
  Bo5
  Bo7
  Bo9
  Bo11
}

enum PickBanStatus {
  Active
  Cancelled
  Complete
}

enum DraftType {
  Snake
  Regular
  Auction
}

enum DraftStatus {
  Active
  Complete
  Cancelled
}

model GuildConfig {
  guildId                  String  @id
  pickBanResultsChannelId  String?
}

model PickBanState {
  id                         String        @id @default(cuid())
  channelId                  String
  guildId                    String
  format                     PickBanFormat
  teamACaptainId             String
  teamBCaptainId             String
  availableMaps              WorldOfTanksMapName[]
  deciderMap                 WorldOfTanksMapName?
  currentStepIndex           Int           @default(0)
  status                     PickBanStatus @default(Active)
  draftMessageId             String
  turnNotificationMessageId  String?
  actions                    PickBanAction[]
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt
}

model PlayerDraftSession {
  id                    String        @id @default(cuid())
  guildId               String
  channelId             String
  numTeams              Int
  maxPlayersPerTeam     Int
  draftType             DraftType
  status                DraftStatus   @default(Active)
  currentPickIndex      Int           @default(0)
  draftMessageId        String?
  captainsChatChannelId String?
  createdChannelIds     String[]      @default([])
  teams                 DraftTeam[]
  players               DraftPlayer[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

model DraftTeam {
  id             Int                @id @default(autoincrement())
  session        PlayerDraftSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId      String
  name           String             
  captainId      String             
  pickOrder      Int?               
  channelId      String?            
  voiceChannelId String?           
  players        DraftPlayer[]

  @@unique([sessionId, pickOrder])
  @@unique([sessionId, name])
  @@unique([sessionId, captainId])
}

model DraftPlayer {
  id               Int                @id @default(autoincrement())
  session          PlayerDraftSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId        String
  discordUsername  String
  discordUserId    String             
  worldOfTanksId   String
  isCaptain        Boolean            @default(false)
  isLegionnaire    Boolean            @default(false)
  wotAccountRegion String
  team             DraftTeam?         @relation(fields: [teamId], references: [id], onDelete: Restrict)
  teamId           Int?               
  pickNumber       Int?              

  @@unique([sessionId, worldOfTanksId])
  @@unique([sessionId, discordUsername])
  @@unique([sessionId, pickNumber])
}

model PickBanAction {
  id         Int               @id @default(autoincrement())
  state      PickBanState      @relation(fields: [stateId], references: [id], onDelete: Cascade)
  stateId    String
  action     PickBanStepAction
  actingTeam ActingTeam
  mapName    WorldOfTanksMapName?
  side       MapSide?
}
